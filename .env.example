# Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=swift_middleware
DB_USERNAME=postgres
DB_PASSWORD=postgres

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# App
SERVER_PORT=8080
LOG_LEVEL=INFO

# HTTP Notification
HTTP_CONNECT_TIMEOUT=5000
HTTP_READ_TIMEOUT=10000
HTTP_MAX_RETRY=3

# Gateway Ports
SAA_PORT=8081
AMH_PORT=8082
